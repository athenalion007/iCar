    "alert.clear_cache_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will clear all cached data including temporary files and images. Your vehicle data will not be affected."
          }
