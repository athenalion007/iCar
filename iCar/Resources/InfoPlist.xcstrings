{
  "sourceLanguage" : "zh-Hans",
  "strings" : {
    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app requires camera access to capture vehicle photos for AI paint damage detection and tire tread depth analysis. All photos are stored only on your device and never uploaded to any server. You can delete these photos at any time within the app."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要使用相机拍摄车辆照片，用于AI漆面损伤检测和轮胎花纹深度分析。拍摄的照片仅存储在您的设备本地，不会上传到任何服务器。您可以随时在应用内删除这些照片。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app needs access to your photo library to save inspection report images and AI analysis results. All data is stored only on your device. You can delete this data at any time in app settings."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要访问您的相册，以便保存检测报告中的车辆照片和AI分析结果。所有数据仅存储在设备本地，不会上传到云端。您可以在应用设置中随时删除这些数据。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Add Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app needs to save inspection reports and AI analysis results to your photo library for easy viewing and sharing. All data is stored only on your device."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要保存检测报告和AI分析结果到您的相册，方便您随时查看和分享。所有数据仅存储在设备本地。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app requires microphone access to record engine sounds for AI fault diagnosis. Recording is processed locally in real-time and never saved or uploaded. Recording data is immediately deleted after analysis."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要使用麦克风录制发动机声音，用于AI故障诊断分析。录音仅在设备本地进行实时分析，不会保存或上传到任何服务器。分析完成后录音数据立即删除。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app needs access to your location to record vehicle inspection locations and help you find nearby auto repair shops. Location data is stored only on your device and not shared with third parties."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要访问您的位置信息，用于记录车辆检测地点，并帮助您查找附近的汽车维修服务站。位置数据仅存储在设备本地，不会分享给第三方。"
          }
        }
      }
    },
    "NSLocationAlwaysUsageDescription" : {
      "comment" : "Privacy - Location Always Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app needs background location access to continuously record vehicle inspection tracks. Location data is stored only on your device and never uploaded or shared with third parties."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要后台访问位置信息，以便在后台持续记录车辆检测轨迹。位置数据仅存储在设备本地，不会上传到服务器或分享给第三方。"
          }
        }
      }
    },
    "NSMotionUsageDescription" : {
      "comment" : "Privacy - Motion Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app uses accelerometer and gyroscope to analyze vehicle suspension vibration for suspension health diagnosis. Motion data is processed locally in real-time and never saved or uploaded."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要使用加速度计和陀螺仪分析车辆悬挂系统的振动情况，用于悬挂健康状态诊断。运动数据仅在设备本地实时处理，不会保存或上传。"
          }
        }
      }
    },
    "NSBluetoothAlwaysUsageDescription" : {
      "comment" : "Privacy - Bluetooth Always Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app requires Bluetooth permission to connect to OBD diagnostic devices to read vehicle fault codes and sensor data. Bluetooth communication is local only and does not collect or transmit any personal data."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要蓝牙权限连接OBD诊断设备，读取车辆故障码和传感器数据。蓝牙通信仅在本地进行，不会收集或传输任何个人数据。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}
